{
  "name": "@dougflip/progression",
  "version": "1.3.1",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "check": "concurrently npm:format:check npm:lint npm:typecheck",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "preview": "vite build && vite preview",
    "test": "vitest run",
    "test:quiet": "vitest run --reporter=dot",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "e2e": "scripts/run-e2e.sh",
    "e2e:update-snapshots": "scripts/run-e2e.sh --update-snapshots"
  },
  "dependencies": {
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "latest",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
