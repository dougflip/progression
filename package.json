{
  "name": "@dougflip/progression",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "concurrently npm:format:check npm:lint npm:typecheck",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "preview": "vite build && vite preview",
    "test": "vitest run",
    "test:quiet": "vitest run --reporter=dot",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "latest",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
